{
  "name": "mali-ai",
  "private": true,
  "scripts": {
    "build": "npx turbo run build --filter=api",
    "dev": "turbo run dev",
    "start": "node apps/api/dist/index.js",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "dependencies": {
    "turbo": "^2.9.3"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.6.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
